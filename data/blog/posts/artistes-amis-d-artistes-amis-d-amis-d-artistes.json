{"post":{"id":"2b71c0c5-693f-4a5a-af1b-3eb7d0c4f5f4","title":"Artistes, Amis d'Artistes, Amis d'Amis d'Artistes...","excerpt":"Devenez Artiste au sein de l'équipe Lalason ! Introduction L'industrie de la musique a toujours été un terrain fertile pour l'expression...","firstPublishedDate":"2023-08-16T12:51:45.260Z","lastPublishedDate":"2023-08-16T12:51:45.260Z","slug":"artistes-amis-d-artistes-amis-d-amis-d-artistes","featured":false,"pinned":false,"categoryIds":[],"memberId":"b3f3fbbd-9b4e-46c0-b0e4-7edc60705954","hashtags":[],"commentingEnabled":true,"minutesToRead":2,"tagIds":[],"relatedPostIds":[],"pricingPlanIds":[],"language":"fr","richContent":{"nodes":[{"type":"PARAGRAPH","id":"foo","nodes":[{"type":"TEXT","id":"","nodes":[],"textData":{"text":"Devenez Artiste au sein de l'équipe Lalason !","decorations":[]}}],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"PARAGRAPH","id":"4hbfr","nodes":[],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"HEADING","id":"4h7qd","nodes":[{"type":"TEXT","id":"","nodes":[],"textData":{"text":"Introduction ","decorations":[{"type":"BOLD","fontWeightValue":700}]}}],"headingData":{"level":2,"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"PARAGRAPH","id":"388o6","nodes":[],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"PARAGRAPH","id":"5lp4k","nodes":[{"type":"TEXT","id":"","nodes":[],"textData":{"text":"L'industrie de la musique a toujours été un terrain fertile pour l'expression artistique et l'innovation. Dans cet écosystème dynamique, Lalason se distingue en tant que plateforme musicale, offrant des opportunités exceptionnelles aux artistes français. Si vous êtes un créateur de musique passionné et talentueux, désireux de faire partie d'une équipe qui redéfinit la musique pour les générations à venir, alors cet article est pour vous ! ","decorations":[]}}],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"PARAGRAPH","id":"v2u8","nodes":[],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"PARAGRAPH","id":"8kcb9","nodes":[{"type":"TEXT","id":"","nodes":[],"textData":{"text":"Découvrons comment Lalason ouvre les portes aux artistes souhaitant rejoindre leurs rangs.","decorations":[]}}],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"PARAGRAPH","id":"djaf7","nodes":[],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"PARAGRAPH","id":"4fi7a","nodes":[],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"VIDEO","id":"asu1c","nodes":[],"videoData":{"containerData":{"width":{"size":"CONTENT"},"alignment":"CENTER","textWrap":true},"video":{"src":{"url":"https://www.youtube.com/watch?v=tP2io2XA9AQ"},"duration":37.0},"thumbnail":{"src":{"url":"https://i.ytimg.com/vi/tP2io2XA9AQ/maxresdefault.jpg"},"width":1280,"height":720}}},{"type":"PARAGRAPH","id":"c8i21","nodes":[],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"PARAGRAPH","id":"2jco0","nodes":[],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"PARAGRAPH","id":"cds8p","nodes":[{"type":"TEXT","id":"","nodes":[],"textData":{"text":"Le Pouvoir de la Collaboration","decorations":[{"type":"ANCHOR","anchorData":{"anchor":"diq4n"}},{"type":"COLOR","colorData":{"foreground":"#547e8b"}},{"type":"UNDERLINE","underlineData":true}]}}],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"PARAGRAPH","id":"buv27","nodes":[{"type":"TEXT","id":"","nodes":[],"textData":{"text":"Liberté Artistique","decorations":[{"type":"ANCHOR","anchorData":{"anchor":"2lj86"}},{"type":"COLOR","colorData":{"foreground":"#547e8b"}},{"type":"UNDERLINE","underlineData":true}]}}],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"PARAGRAPH","id":"fa743","nodes":[{"type":"TEXT","id":"","nodes":[],"textData":{"text":"Accès à une Audience Mondiale","decorations":[{"type":"ANCHOR","anchorData":{"anchor":"c24u8"}},{"type":"COLOR","colorData":{"foreground":"#547e8b"}},{"type":"UNDERLINE","underlineData":true}]}},{"type":"TEXT","id":"","nodes":[],"textData":{"text":" ","decorations":[{"type":"COLOR","colorData":{"foreground":"#547e8b"}}]}}],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"PARAGRAPH","id":"7rslq","nodes":[{"type":"TEXT","id":"","nodes":[],"textData":{"text":"Rémunération Équitable","decorations":[{"type":"ANCHOR","anchorData":{"anchor":"9un8c"}},{"type":"COLOR","colorData":{"foreground":"#547e8b"}},{"type":"UNDERLINE","underlineData":true}]}}],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"PARAGRAPH","id":"2rhjn","nodes":[{"type":"TEXT","id":"","nodes":[],"textData":{"text":"Comment Rejoindre l'Équipe","decorations":[{"type":"ANCHOR","anchorData":{"anchor":"dl337"}},{"type":"COLOR","colorData":{"foreground":"#547e8b"}},{"type":"UNDERLINE","underlineData":true}]}}],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"PARAGRAPH","id":"7jsf4","nodes":[],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"PARAGRAPH","id":"dod4a","nodes":[],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"DIVIDER","id":"v2k2","nodes":[],"dividerData":{"containerData":{"width":{"size":"CONTENT"},"alignment":"CENTER","textWrap":false},"lineStyle":"SINGLE","width":"LARGE","alignment":"CENTER"}},{"type":"HEADING","id":"51jtp","nodes":[],"headingData":{"level":2,"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"PARAGRAPH","id":"3b33g","nodes":[],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"HEADING","id":"diq4n","nodes":[{"type":"TEXT","id":"","nodes":[],"textData":{"text":"Le Pouvoir de la Collaboration ","decorations":[{"type":"BOLD","fontWeightValue":700}]}}],"headingData":{"level":2,"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"HEADING","id":"2vd4m","nodes":[],"headingData":{"level":2,"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"PARAGRAPH","id":"f7b2u","nodes":[{"type":"TEXT","id":"","nodes":[],"textData":{"text":"Lalason ne se contente pas d'être une simple bibliothèque de musique. C'est un écosystème créatif qui célèbre la collaboration entre artistes, producteurs et créateurs de contenu. En rejoignant l'équipe Lalason, vous ne devenez pas seulement un membre, mais un maillon essentiel de la chaîne de création musicale. Votre art contribuera à alimenter des projets passionnants, des vidéos YouTube captivantes aux publicités percutantes en passant par des productions cinématographiques émouvantes.","decorations":[]}}],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"PARAGRAPH","id":"ab2t6","nodes":[],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"PARAGRAPH","id":"eh0mg","nodes":[],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"HEADING","id":"2lj86","nodes":[{"type":"TEXT","id":"","nodes":[],"textData":{"text":"Liberté Artistique ","decorations":[{"type":"BOLD","fontWeightValue":700}]}}],"headingData":{"level":2,"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"PARAGRAPH","id":"b788p","nodes":[],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"PARAGRAPH","id":"d8r04","nodes":[{"type":"TEXT","id":"","nodes":[],"textData":{"text":"Lalason comprend que la créativité s'épanouit lorsque les artistes sont libres d'explorer de nouvelles idées et de repousser les limites conventionnelles. En tant qu'artiste au sein de l'équipe, vous conserverez un contrôle total sur votre travail. Vous aurez la possibilité de créer différents styles musicaux, des pistes énergiques pour des vidéos sportives aux mélodies apaisantes pour des projets de bien-être.","decorations":[]}}],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"PARAGRAPH","id":"89isf","nodes":[],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"PARAGRAPH","id":"bhb09","nodes":[],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"HEADING","id":"c24u8","nodes":[{"type":"TEXT","id":"","nodes":[],"textData":{"text":"Accès à une Audience Mondiale","decorations":[{"type":"BOLD","fontWeightValue":700}]}},{"type":"TEXT","id":"","nodes":[],"textData":{"text":" ","decorations":[]}}],"headingData":{"level":2,"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"PARAGRAPH","id":"2bfq2","nodes":[],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"PARAGRAPH","id":"1p840","nodes":[{"type":"TEXT","id":"","nodes":[],"textData":{"text":"L'une des caractéristiques les plus remarquables de Lalason est sa portée mondiale. Votre musique ne se cantonnera pas à un seul coin du globe. En collaborant avec Lalason, vos créations atteindront un public mondial, touchant des auditeurs aux horizons culturels divers, grâce à la chaine Youtube ","decorations":[]}},{"type":"TEXT","id":"","nodes":[],"textData":{"text":"La Musique Libre","decorations":[{"type":"COLOR","colorData":{"foreground":"#547e8b"}},{"type":"LINK","linkData":{"link":{"url":"https://www.youtube.com/@LaMusiqueLibre","target":"BLANK"}}},{"type":"UNDERLINE","underlineData":true}]}},{"type":"TEXT","id":"","nodes":[],"textData":{"text":". Cette opportunité d'atteindre un public mondial peut ouvrir des portes insoupçonnées pour votre carrière artistique.","decorations":[]}}],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"PARAGRAPH","id":"965hf","nodes":[],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"PARAGRAPH","id":"39qb2","nodes":[],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"HEADING","id":"9un8c","nodes":[{"type":"TEXT","id":"","nodes":[],"textData":{"text":"Rémunération Équitable","decorations":[{"type":"BOLD","fontWeightValue":700}]}},{"type":"TEXT","id":"","nodes":[],"textData":{"text":" ","decorations":[]}}],"headingData":{"level":2,"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"PARAGRAPH","id":"69fm1","nodes":[],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"PARAGRAPH","id":"bjfh2","nodes":[{"type":"TEXT","id":"","nodes":[],"textData":{"text":"Chez Lalason, les artistes sont valorisés à leur juste mesure. Le modèle économique innovant de Lalason garantit que les artistes reçoivent une rémunération équitable pour leur travail. Votre contribution sera reconnue et récompensée, vous permettant de poursuivre votre passion tout en gagnant votre vie.","decorations":[]}}],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"PARAGRAPH","id":"bfulg","nodes":[],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"PARAGRAPH","id":"csmuk","nodes":[],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"HEADING","id":"dl337","nodes":[{"type":"TEXT","id":"","nodes":[],"textData":{"text":"Comment Rejoindre l'Équipe","decorations":[{"type":"BOLD","fontWeightValue":700}]}},{"type":"TEXT","id":"","nodes":[],"textData":{"text":" ","decorations":[]}}],"headingData":{"level":2,"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"PARAGRAPH","id":"9h2nd","nodes":[],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"PARAGRAPH","id":"9f6ld","nodes":[{"type":"TEXT","id":"","nodes":[],"textData":{"text":"Si vous êtes enthousiaste à l'idée de rejoindre notre communauté, le processus est simple et transparent. Il suffit de remplir ce ","decorations":[]}},{"type":"TEXT","id":"","nodes":[],"textData":{"text":"Google Form","decorations":[{"type":"COLOR","colorData":{"foreground":"#547e8b"}},{"type":"LINK","linkData":{"link":{"url":"https://forms.gle/upeDA9VQ9eBvwyJq9","target":"BLANK"}}},{"type":"UNDERLINE","underlineData":true}]}},{"type":"TEXT","id":"","nodes":[],"textData":{"text":". Vous y trouverez des informations sur la manière de soumettre vos créations. Tous types de musique sont acceptés. Les critères de sélection ? ","decorations":[]}},{"type":"TEXT","id":"","nodes":[],"textData":{"text":"Etre passionné et produire de la musique de grande qualité pour les créateurs de contenus. ","decorations":[{"type":"BOLD","fontWeightValue":700}]}}],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"PARAGRAPH","id":"e30at","nodes":[],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"PARAGRAPH","id":"e66rk","nodes":[],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"PARAGRAPH","id":"1gab8","nodes":[],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"HEADING","id":"cjjml","nodes":[{"type":"TEXT","id":"","nodes":[],"textData":{"text":"Conclusion ","decorations":[{"type":"BOLD","fontWeightValue":700}]}}],"headingData":{"level":2,"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"PARAGRAPH","id":"9s1b7","nodes":[],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"PARAGRAPH","id":"c4lqj","nodes":[{"type":"TEXT","id":"","nodes":[],"textData":{"text":"Lalason n'est pas seulement une plateforme musicale, c'est une communauté vibrante d'artistes et de créateurs dédiés à l'exploration sonore. En rejoignant notre équipe, vous ouvrez la porte à des opportunités créatives infinies, tout en élargissant votre audience et en développant votre carrière musicale. Si vous aspirez à collaborer avec des esprits créatifs et à impacter le monde de la musique, ne cherchez pas plus loin que Lalason. ","decorations":[]}}],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"PARAGRAPH","id":"aheks","nodes":[],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}},{"type":"PARAGRAPH","id":"2qvjk","nodes":[{"type":"TEXT","id":"","nodes":[],"textData":{"text":"Rejoignez cette aventure musicale et contribuez au rayonnement de la French touch!","decorations":[]}}],"paragraphData":{"textStyle":{"textAlignment":"AUTO"},"indentation":0}}],"metadata":{"version":1,"createdTimestamp":"2024-06-08T01:46:03.915Z","updatedTimestamp":"2024-06-08T01:46:03.915Z","id":"4ad851ae-a68d-407f-9751-07fc93aa13bf"},"documentStyle":{}},"preview":false,"contentId":"64dcc6611c3da36f56b57ac9","mostRecentContributorId":"032c124f-618c-4ccb-91db-e22a07b368fd","media":{"wixMedia":{"image":{"id":"b3f3fb_9a67e712a9c84d1d897eb88525fd5aba~mv2.webp","url":"https://static.wixstatic.com/media/b3f3fb_9a67e712a9c84d1d897eb88525fd5aba~mv2.webp","height":720,"width":1280}},"displayed":true,"custom":true},"hasUnpublishedChanges":false,"translations":[],"customExcerpt":false,"internalCategoryIds":[],"internalRelatedPostIds":[]}}